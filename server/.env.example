# ========================================
# Server Configuration
# ========================================
PORT=5000
NODE_ENV=development

# ========================================
# Database Configuration
# ========================================
# LOCAL DEVELOPMENT:
# MONGODB_URI=mongodb://localhost:27017/dating_app

# MONGODB ATLAS (Production/Render):
# Get this from MongoDB Atlas → Connect → Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/dating_app?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dating_app?retryWrites=true&w=majority

JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=30d

# ========================================
# Cloudinary Configuration (Image Upload)
# ========================================
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========================================
# Frontend URL (for CORS)
# ========================================
# LOCAL: http://localhost:19000
# PRODUCTION: Your expo app's URL or domain
FRONTEND_URL=http://localhost:19000
